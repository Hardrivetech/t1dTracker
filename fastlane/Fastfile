default_platform(:android)

platform :android do
  desc "Build debug APK"
  lane :assemble_debug do
    gradle(task: "clean assembleDebug")
  end

  desc "Build release bundle (signing config required in CI)"
  lane :release do
    gradle(task: "clean bundleRelease")
    UI.message("Release bundle generated. Configure Fastlane supply or Play Store upload in CI.")
  end
end
